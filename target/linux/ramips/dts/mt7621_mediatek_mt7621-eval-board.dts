#include "mt7621.dtsi"

/ {
	compatible = "mediatek,mt7621-eval-board", "mediatek,mt7621-soc";
	model = "Mediatek MT7621 evaluation board";
};

&nand {
	status = "disabled"; /* Changed from okay to disabled */
};

&sdhci {
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&sdhci_pins>;
};

&ethernet {
	pinctrl-0 = <&mdio_pins>, <&rgmii1_pins>;
};

&switch0 {
	ports {
		port@0 {
			status = "okay";
			label = "lan1";
		};

		port@1 {
			status = "okay";
			label = "lan2";
		};

		port@2 {
			status = "okay";
			label = "lan3";
		};

		port@3 {
			status = "okay";
			label = "lan4";
		};

		port@4 {
			status = "okay";
			label = "wan";
		};
	};
};

&state_default {
	gpio {
		/* REMOVED "sdhci" from the list below */
		/* Correct: We removed "i2c" and "uart2" etc. from here */
		groups = "uart3", "rgmii2"; 
		function = "gpio";
	};

	/* ADD THIS: Explicitly disable JTAG to free up Pin 41 */
	jtag {
		groups = "jtag";
		function = "gpio";
	};
};

&i2c {
    status = "okay";

    pinctrl-names = "default";
    pinctrl-0 = <&i2c_pins>;

    rtc@68 {
        compatible = "ti,bq32000";
        reg = <0x68>;
    };
};

